# mac-app-init 환경변수
# 이 파일을 ~/.env 로 복사 후 dotenvx encrypt 실행

# ─── 디렉토리 (HOME 기준 상대 경로) ───────────────────
SYSTEM_DIR=문서/시스템
SYSTEM_BIN=문서/시스템/bin
SYSTEM_LOG=문서/시스템/로그
PROJECT_DIR=문서/프로젝트
MEDIA_DIR=문서/미디어
ARCHIVE_DIR=문서/아카이브
TEMP_DIR=문서/임시

# ─── 인프라 (선택, domain.ncl 활성화 시 필요) ──────────
# PROXMOX_HOST=192.168.x.x
# PROXMOX_USER=root
# SYNOLOGY_HOST=192.168.x.x
# SYNOLOGY_USER=user
# SYNOLOGY_PASSWORD=
# MOUNT_PASSWORD=
# DALCENTER_URL=http://x.x.x.x:11192
# VAULTCENTER_URL=http://x.x.x.x:11181
# LOCALVAULT_URL=http://127.0.0.1:10180

# ─── API 키 (선택) ────────────────────────────────────
# GEMINI_API_KEY=
# CLOUD_FLARE_API_KEY=
# CLOUD_FLARE_EMAIL=
