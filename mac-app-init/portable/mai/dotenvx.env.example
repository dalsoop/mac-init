# Copy to portable/mai/dotenvx.env and encrypt with dotenvx before committing.
# `mai setup` copies this file to ~/.env when ~/.env does not already exist.
#
# Example:
#   cp portable/mai/dotenvx.env.example portable/mai/dotenvx.env
#   dotenvx encrypt -f portable/mai/dotenvx.env
#
# Required secrets depend on which portable cards and domains you use.
PROXMOX50_HOST=192.168.2.50
PROXMOX50_USER=root
PROXMOX50_REALM=pam
PROXMOX50_WEB_PORT=8006
# PROXMOX50_PASSWORD=
PROXMOX60_HOST=192.168.2.60
PROXMOX60_USER=root
PROXMOX60_REALM=pam
PROXMOX60_WEB_PORT=8006
# PROXMOX60_PASSWORD=
# TRUENAS_PASSWORD=
# SYNOLOGY_PASSWORD=
